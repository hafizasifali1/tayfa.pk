{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,

    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "lib": ["ES2022"],
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowJs": true,

    "outDir": "./dist",
    "rootDir": "./",
    "noEmit": false,

    "jsx": "react-jsx",

    "paths": {
      "@/*": ["./*"]
    }
  },
  "include": ["server.ts", "src/server/**/*", "src/db/**/*"],
  "exclude": ["node_modules", "dist"]
}